import random

def get_length():
    length = int(input("Enter password length: "))
    return length
    
def get_options():
    include_upper = input("Include uppercase? ").strip().lower()
    include_lower = input("Include lowercase? ").strip().lower()
    include_nums  = input("Include numbers? ").strip().lower()
    return include_upper, include_lower, include_nums

def build_pool(include_upper, include_lower, include_nums):
    choose = ""

    if include_upper == "yes":
        choose = choose + "ABCDEFGHIJKLMNOPQRSTUVWXYZ"

    if include_lower == "yes":
        choose = choose + "abcdefghijklmnopqrstuvwxyz"

    if include_nums == "yes":
        choose = choose + "0123456789"

    return choose
    
def generate_password(length, choose):
    if choose == "":
        return None

    password = ""
    i = 0
    while i < length:
        password = password + random.choice(choose)
        i = i + 1

    return password
    
def main():
    length = get_length()
    include_upper, include_lower, include_nums = get_options()

    pool = build_pool(include_upper, include_lower, include_nums)

    password = generate_password(length, pool)

    print()

    if password is None:
        print("No character types selected. Cannot generate password.")
    else:
        print("Generated Password: " + password)
        print()
        print("Password generated with " + str(length) + " length")
        
if __name__ == "__main__":
    main()
